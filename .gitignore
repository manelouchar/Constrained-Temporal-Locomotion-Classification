# ==================== Data ====================
# Raw data (too large for git)
data/raw/*.npz
data/raw/*.npy
data/raw/*.csv
data/raw/*.h5
data/raw/*.mat

# Processed data
data/processed/*.npz
data/processed/*.npy
data/processed/*.pkl

# Features
data/features/*.npz
data/features/*.npy

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/features/.gitkeep

# ==================== Results ====================
# Figures (generated during experiments)
results/figures/*.png
results/figures/*.jpg
results/figures/*.pdf
results/figures/*.svg

# Tables
results/tables/*.csv
results/tables/*.xlsx

# Metrics
results/metrics/*.json
results/metrics/*.pkl

# Keep structure
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/metrics/.gitkeep

